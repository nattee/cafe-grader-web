-# topic filter badge

.card.card-shadow
  .card-body
    %h5.fw-bold Problems
    - if @primary_tags.count > 0
      .row
        .col-auto
          Topic:
        .col-auto
          - @primary_tags.each do |tag|
            - data_hash = { action: 'click->main#setActiveTopic',  bs: tag.description.present? ?  { toggle: 'tooltip', title: tag.description } : nil }
            %span.badge.topic-badge.text-bg-light.border.border-dark-subtle.text-body-tertiary.me-1{data: data_hash, style: 'cursor: pointer'}= tag.name
    %table#main_table.table.table-striped.table-condensed{width: '100%', 'data-controller' => 'init-ui-component'}
      %thead
        %tr
          %th No.
          %th.all Name
          %th Best Score
          %th.all Latest Results
          %th.all
      %tbody{data: {controller: 'problem-name'}}
        - @numbering = 1
        / problem count = #{problems.count}
        = render partial: 'problem', collection: problems
